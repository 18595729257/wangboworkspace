/* pages/my/my.wxss */

.hero-card {
  background: linear-gradient(160deg, #007AFF 0%, #0055D4 100%);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.25);
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
}

.user-info { flex: 1; }

.username {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.openid-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  word-break: break-all;
  margin-top: 4rpx;
}

.edit-link {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.login-pill {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: none;
  border-radius: var(--radius-full);
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.login-pill::after { border: none; }

.points-strip {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.points-num {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.points-label {
  font-size: 26rpx;
  margin-left: 8rpx;
  opacity: 0.9;
}

.points-link {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--blue);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--label-secondary);
  margin-top: 6rpx;
}

/* 菜单列表 */
.menu-list {
  padding: 4rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.menu-item:last-child { border-bottom: none; }

.menu-icon {
  font-size: 36rpx;
  margin-right: 18rpx;
  width: 44rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--label-tertiary);
  font-weight: 300;
}

/* 步骤 */
.steps {
  padding: 4rpx 0;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 122, 255, 0.08);
  color: var(--blue);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: var(--label-secondary);
}
