/* pages/order-detail/order-detail.wxss */

/* 状态横幅 */
.status-banner {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  color: #ffffff;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
}

.status-banner.status-pending { background: linear-gradient(160deg, #FF9500 0%, #E08600 100%); }
.status-banner.status-paid { background: linear-gradient(160deg, #007AFF 0%, #0055D4 100%); }
.status-banner.status-printing { background: linear-gradient(160deg, #AF52DE 0%, #8944AB 100%); }
.status-banner.status-completed { background: linear-gradient(160deg, #34C759 0%, #2DA44E 100%); }
.status-banner.status-cancelled { background: linear-gradient(160deg, #8E8E93 0%, #636366 100%); }

.status-icon {
  font-size: 56rpx;
  margin-right: 22rpx;
}

.status-text {
  font-size: 34rpx;
  font-weight: 600;
}

/* 信息列表 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.info-item:last-child { border-bottom: none; }

.info-label {
  font-size: 28rpx;
  color: var(--label-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--label);
}

/* 文件卡片 */
.file-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.file-icon {
  font-size: 44rpx;
  margin-right: 18rpx;
}

.file-info { flex: 1; }

.file-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--label);
  margin-bottom: 4rpx;
  word-break: break-all;
}

.file-setting {
  font-size: 22rpx;
  color: var(--label-secondary);
}

/* 价格 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: var(--label-secondary);
}

.price-value {
  font-size: 28rpx;
  color: var(--label);
}

.price-row.discount .price-value { color: var(--green); }

.price-row.total .price-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--label);
}

/* 操作 */
.action-section {
  margin-top: 40rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 【升级v2】取单号大字展示 ===== */

.pickup-hero {
  background: linear-gradient(135deg, #007AFF, #5AC8FA);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.pickup-hero-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.pickup-hero-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.pickup-hero-code {
  font-size: 96rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 12rpx;
  font-family: 'Courier New', monospace;
  line-height: 1;
}

.pickup-hero-tip {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

/* 订单详情页取单号文字 */
.pickup-code-text {
  color: #007AFF !important;
  font-weight: 700;
  font-size: 32rpx !important;
}

.action-section button {
  margin-bottom: 18rpx;
}

.action-section button:last-child { margin-bottom: 0; }

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--label-secondary);
  font-size: 28rpx;
}
