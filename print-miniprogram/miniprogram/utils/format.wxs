module.exports = {
  formatPrice: function(price) {
    if (price === null || price === undefined || price === '') return '0.00'
    var num = parseFloat(price)
    if (isNaN(num)) return '0.00'
    return num.toFixed(2)
  },

  formatSize: function(bytes) {
    if (!bytes) return '0 KB'
    return (bytes / 1024).toFixed(1) + ' KB'
  },

  formatTime: function(dateStr) {
    if (!dateStr) return ''
    var s = '' + dateStr
    // 找 T 或空格，分割日期和时间
    var tIdx = s.indexOf('T')
    var spaceIdx = s.indexOf(' ')
    var sep = tIdx >= 0 ? tIdx : spaceIdx
    if (sep < 0) return s
    // 日期部分：取 T 前的 yyyy-MM-dd
    var datePart = s.substring(0, sep)
    var ymd = datePart
    var dp = ymd.split('-')
    if (dp.length !== 3) return ymd
    var y = dp[0], m = dp[1], d = dp[2]
    // 时间部分：T 之后的内容
    var rawTime = s.substring(sep + 1)
    // 去掉 .xxx（毫秒）和 Z / +08:00 等时区后缀
    // 找第一个非数字非冒号字符
    var dot = rawTime.indexOf('.')
    var timeOnly = dot >= 0 ? rawTime.substring(0, dot) : rawTime
    var z = timeOnly.indexOf('Z')
    if (z >= 0) timeOnly = timeOnly.substring(0, z)
    var plus = timeOnly.indexOf('+')
    if (plus >= 0) timeOnly = timeOnly.substring(0, plus)
    // timeOnly 现在是纯 hh:mm:ss
    var p = timeOnly.split(':')
    var h = (p[0] && p[0].length > 0) ? p[0] : '00'
    var mn = (p[1] && p[1].length > 0) ? p[1] : '00'
    var sec = (p[2] && p[2].length > 0) ? p[2] : '00'
    return y + '-' + m + '-' + d + ' ' + h + ':' + mn + ':' + sec
  }
}
