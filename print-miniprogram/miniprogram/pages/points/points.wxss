/* pages/points/points.wxss */

/* 积分概览 */
.points-overview {
  background: linear-gradient(160deg, #FF9500 0%, #E08600 100%);
  color: #ffffff;
  text-align: center;
  padding: 50rpx 30rpx;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.25);
  margin-bottom: 24rpx;
}

.points-value {
  font-size: 88rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.points-label {
  font-size: 30rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.points-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 规则 */
.rule-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.rule-item:last-child { border-bottom: none; }

.rule-icon {
  font-size: 36rpx;
  margin-right: 18rpx;
  width: 48rpx;
  text-align: center;
}

.rule-info { flex: 1; }

.rule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--label);
  margin-bottom: 4rpx;
}

.rule-desc {
  font-size: 22rpx;
  color: var(--label-secondary);
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--label);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--label-tertiary);
}

/* 记录列表 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.record-item:last-child { border-bottom: none; }

.record-info { flex: 1; }

.record-reason {
  font-size: 28rpx;
  color: var(--label);
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 20rpx;
  color: var(--label-tertiary);
}

.record-points {
  font-size: 36rpx;
  font-weight: 700;
}

.record-points.earn { color: var(--green); }
.record-points.consume { color: var(--red); }
.record-points.refund { color: var(--blue); }

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: var(--label-tertiary);
}
