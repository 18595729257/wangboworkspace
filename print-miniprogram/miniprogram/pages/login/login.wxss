/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  background: var(--bg);
}

.header {
  background: linear-gradient(160deg, #007AFF 0%, #0055D4 100%);
  padding: 70rpx 40rpx 50rpx;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-bottom: 18rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.auth-list {
  padding: 32rpx 32rpx 0;
}

.auth-item {
  background: var(--card);
  border-radius: var(--radius);
  padding: 26rpx 28rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow);
}

.auth-info {
  display: flex;
  flex-direction: column;
}

.auth-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--label);
}

.auth-status {
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 4rpx;
}

.auth-status.done {
  color: var(--green);
}

.auth-btn {
  background: rgba(0, 122, 255, 0.08);
  color: var(--blue);
  border: none;
  border-radius: var(--radius-sm);
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  min-width: 160rpx;
  text-align: center;
}

.auth-btn::after { border: none; }

.auth-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.auth-input {
  width: 180rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--label);
  padding: 12rpx 0;
}

.main-btn {
  margin: 36rpx 32rpx 0;
  height: 96rpx;
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-btn::after { border: none; }
.main-btn:active { opacity: 0.85; }

.skip {
  text-align: center;
  font-size: 26rpx;
  color: var(--label-tertiary);
  margin-top: 28rpx;
  padding-bottom: 60rpx;
}
