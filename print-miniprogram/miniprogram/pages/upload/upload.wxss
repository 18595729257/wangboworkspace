/* pages/upload/upload.wxss */

/* 文件选择器 */
.file-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 70rpx 30rpx;
  border: 3rpx dashed var(--separator-strong);
  border-radius: var(--radius);
  background: var(--bg);
}

.file-picker:active {
  border-color: var(--blue);
  background: rgba(0, 122, 255, 0.03);
}

.picker-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.picker-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--label);
  margin-bottom: 8rpx;
}

.picker-hint {
  font-size: 24rpx;
  color: var(--label-tertiary);
}

/* 已选文件 */
.file-selected {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(0, 122, 255, 0.04);
  border-radius: var(--radius);
  border: 1rpx solid rgba(0, 122, 255, 0.12);
}

.file-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.file-icon {
  font-size: 44rpx;
  margin-right: 18rpx;
}

.file-detail { flex: 1; }

.file-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--label);
  word-break: break-all;
}

.file-size {
  font-size: 22rpx;
  color: var(--label-secondary);
  margin-top: 4rpx;
}

.file-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.file-page-status {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.file-page-status.parsing {
  color: var(--orange, #FF9500);
  background: rgba(255, 149, 0, 0.1);
}

.file-page-status.ready {
  color: var(--green, #34C759);
  background: rgba(52, 199, 89, 0.1);
}

.file-remove {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 59, 48, 0.1);
  color: var(--red);
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 700;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.setting-item:last-child { border-bottom: none; }

.setting-label {
  font-size: 28rpx;
  color: var(--label);
}

.setting-value {
  display: flex;
  align-items: center;
}

.setting-value input {
  width: 120rpx;
  height: 64rpx;
  text-align: center;
  border: none;
  background: var(--bg);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  margin-right: 10rpx;
  color: var(--label);
}

.setting-unit {
  font-size: 24rpx;
  color: var(--label-secondary);
}

.setting-options {
  display: flex;
  gap: 14rpx;
}

.option {
  padding: 12rpx 28rpx;
  background: var(--bg);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--label-secondary);
  font-weight: 500;
}

.option.active {
  background: var(--blue);
  color: #ffffff;
}

/* 积分 */
.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
}

.points-label {
  font-size: 28rpx;
  color: var(--label);
}

.points-balance {
  font-size: 24rpx;
  color: var(--blue);
}

.points-input {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--separator);
}

.points-hint {
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 10rpx;
}

/* 价格 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: var(--label-secondary);
}

.price-value {
  font-size: 28rpx;
  color: var(--label);
}

.price-row.discount .price-value {
  color: var(--green);
}

.price-row.total .price-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--label);
}

/* 提交 */
.submit-area {
  margin-top: 32rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  border-radius: var(--radius);
}

.submit-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 16rpx;
}

/* 文件来源弹窗 */
.action-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.action-sheet {
  width: 100%;
  background: var(--card);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.action-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--label-secondary);
  padding: 28rpx 0 20rpx;
  border-bottom: 1rpx solid var(--separator);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid var(--separator);
}

.action-item:active {
  background: var(--bg);
}

.action-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  background: rgba(0, 122, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
}

.action-icon {
  font-size: 32rpx;
  color: var(--blue);
}

.action-info {
  flex: 1;
}

.action-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--label);
  display: block;
}

.action-desc {
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 4rpx;
  display: block;
}

.action-cancel {
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: var(--label-secondary);
  margin-top: 12rpx;
  background: var(--card);
}

.action-cancel:active {
  background: var(--bg);
}

/* 多文件列表 */
.file-list { display: flex; flex-direction: column; gap: 16rpx; }
.file-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; background: rgba(0, 122, 255, 0.04); border-radius: var(--radius); border: 1rpx solid rgba(0, 122, 255, 0.12); }
.file-item .file-icon { font-size: 40rpx; margin-right: 16rpx; flex-shrink: 0; }
.file-item .file-detail { flex: 1; min-width: 0; }
.file-item .file-name { font-size: 28rpx; font-weight: 500; color: var(--label); margin-bottom: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.file-item .file-meta { display: flex; align-items: center; gap: 16rpx; font-size: 24rpx; }
.file-item .file-status { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 8rpx; }
.file-item .file-status.parsing { color: #FF9500; background: rgba(255, 149, 0, 0.1); }
.file-item .file-status.ready { color: #34C759; background: rgba(52, 199, 89, 0.1); }
.file-item .file-status.error { color: #FF3B30; background: rgba(255, 59, 48, 0.1); }
.file-add { display: flex; align-items: center; justify-content: center; padding: 30rpx; border: 2rpx dashed var(--separator-strong); border-radius: var(--radius); background: var(--bg); gap: 12rpx; }
.file-add:active { border-color: var(--blue); background: rgba(0, 122, 255, 0.03); }
.add-icon { font-size: 36rpx; color: var(--blue); }
.add-text { font-size: 28rpx; color: var(--blue); }
.page-total { font-size: 32rpx; font-weight: 600; color: var(--blue); }

