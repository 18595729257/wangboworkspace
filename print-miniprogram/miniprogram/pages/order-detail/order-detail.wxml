<!--pages/order-detail/order-detail.wxml-->
<wxs src="/utils/format.wxs" module="fmt" />
<view class="container">
  <!-- 订单状态 -->
  <view wx:if="{{orderInfo}}" class="status-banner status-{{orderInfo.status}}">
    <view class="status-icon">
      <text wx:if="{{orderInfo.status === 'pending'}}">…</text>
      <text wx:elif="{{orderInfo.status === 'paid'}}">✓</text>
      <text wx:elif="{{orderInfo.status === 'printing'}}">⋯</text>
      <text wx:elif="{{orderInfo.status === 'completed'}}">✓</text>
      <text wx:elif="{{orderInfo.status === 'cancelled'}}">✕</text>
    </view>
    <view class="status-text">
      <text wx:if="{{orderInfo.status === 'pending'}}">待支付</text>
      <text wx:elif="{{orderInfo.status === 'paid'}}">已支付，等待打印</text>
      <text wx:elif="{{orderInfo.status === 'printing'}}">正在打印中...</text>
      <text wx:elif="{{orderInfo.status === 'completed'}}">打印完成</text>
      <text wx:elif="{{orderInfo.status === 'cancelled'}}">订单已取消</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view wx:if="{{orderInfo}}" class="card">
    <view class="card-title">订单信息</view>
    
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">订单号</text>
        <text class="info-value">{{orderInfo.orderNo}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">创建时间</text>
        <text class="info-value">{{fmt.formatTime(orderInfo.createTime)}}</text>
      </view>
      
      <view class="info-item" wx:if="{{orderInfo.payTime}}">
        <text class="info-label">支付时间</text>
        <text class="info-value">{{fmt.formatTime(orderInfo.payTime)}}</text>
      </view>
      
      <view class="info-item" wx:if="{{orderInfo.printStartTime}}">
        <text class="info-label">开始打印</text>
        <text class="info-value">{{fmt.formatTime(orderInfo.printStartTime)}}</text>
      </view>
      
      <view class="info-item" wx:if="{{orderInfo.printEndTime}}">
        <text class="info-label">打印完成</text>
        <text class="info-value">{{fmt.formatTime(orderInfo.printEndTime)}}</text>
      </view>
    </view>
  </view>

  <!-- 文件信息 -->
  <view wx:if="{{orderInfo}}" class="card">
    <view class="card-title">文件信息</view>
    
    <view class="file-card">
      <view class="file-icon">📎</view>
      <view class="file-info">
        <view class="file-name">{{orderInfo.fileName}}</view>
        <view class="file-setting">{{orderInfo.pageCount}}页 × {{orderInfo.copies}}份 × {{orderInfo.colorMode === 'color' ? '彩色' : '黑白'}} × {{orderInfo.paperSize}}</view>
      </view>
    </view>
  </view>

  <!-- 价格明细 -->
  <view wx:if="{{orderInfo}}" class="card price-card">
    <view class="card-title">价格明细</view>
    
    <view class="price-row">
      <text class="price-label">打印费用</text>
      <text class="price-value">¥{{fmt.formatPrice(orderInfo.printFee)}}</text>
    </view>
    
    <view class="price-row">
      <text class="price-label">服务费</text>
      <text class="price-value">¥{{fmt.formatPrice(orderInfo.serviceFee)}}</text>
    </view>
    
    <view wx:if="{{orderInfo.pointsDiscount > 0}}" class="price-row discount">
      <text class="price-label">积分抵扣（{{orderInfo.pointsUsed}}积分）</text>
      <text class="price-value">-¥{{fmt.formatPrice(orderInfo.pointsDiscount)}}</text>
    </view>
    
    <view class="divider"></view>
    
    <view class="price-row total">
      <text class="price-label">实付金额</text>
      <text class="price-value price-large">¥{{fmt.formatPrice(orderInfo.actualPay)}}</text>
    </view>
  </view>

  <!-- 打印机信息 -->
  <view wx:if="{{orderInfo && orderInfo.printerId}}" class="card">
    <view class="card-title">打印机信息</view>
    <view class="info-item">
      <text class="info-label">打印机ID</text>
      <text class="info-value">{{orderInfo.printerId}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view wx:if="{{orderInfo}}" class="action-section">
    <button wx:if="{{orderInfo.status === 'pending'}}" class="btn-primary" bindtap="payOrder">立即支付</button>
    <button wx:if="{{orderInfo.status === 'pending'}}" class="btn-secondary" bindtap="cancelOrder">取消订单</button>
    <button wx:if="{{orderInfo.status === 'completed'}}" class="btn-primary" bindtap="goBack">返回</button>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{!orderInfo}}" class="loading">
    <text>加载中...</text>
  </view>
</view>
