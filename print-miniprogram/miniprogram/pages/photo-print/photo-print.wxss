/* pages/photo-print/photo-print.wxss */

/* 类别列表 */
.cat-list { padding: 4rpx 0; }

.cat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.cat-item:last-child { border-bottom: none; }

.cat-item.active .cat-name { color: var(--blue); }

.cat-main { flex: 1; }

.cat-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--label);
}

.cat-desc {
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 4rpx;
  display: block;
}

.cat-price {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--red);
}

/* 选项 */
.option-group {
  display: flex;
  gap: 14rpx;
}

.option-pill {
  flex: 1;
  text-align: center;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--bg);
  font-size: 24rpx;
  color: var(--label-secondary);
  font-weight: 500;
}

.option-pill.active {
  background: var(--blue);
  color: #ffffff;
}

/* 底色选择 */
.bg-options {
  display: flex;
  gap: 30rpx;
}

.bg-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bg-item text {
  font-size: 24rpx;
  color: var(--label-secondary);
}

.bg-item.active text { color: var(--blue); font-weight: 600; }

.bg-preview {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid var(--separator);
}

.bg-item.active .bg-preview { border-color: var(--blue); }
.bg-white { background: #ffffff; }
.bg-blue { background: #438EDB; }
.bg-red { background: #E84040; }

/* 上传 */
.upload-area {
  width: 100%;
  aspect-ratio: 1;
  max-width: 400rpx;
  margin: 0 auto;
  border: 3rpx dashed var(--separator-strong);
  border-radius: var(--radius);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

.upload-preview { width: 100%; height: 100%; }

.upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.4);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.upload-plus {
  font-size: 64rpx;
  color: var(--label-tertiary);
  line-height: 1;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--label-secondary);
  margin-top: 10rpx;
}

/* 份数 */
.copies-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.copies-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.copies-num {
  font-size: 36rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

/* 价格 */
.price-summary { margin-top: 8rpx; }

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-key { font-size: 28rpx; color: var(--label-secondary); }

.price-large {
  font-size: 48rpx;
  color: var(--red);
  font-weight: 700;
}

/* 提交 */
.submit-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
}
