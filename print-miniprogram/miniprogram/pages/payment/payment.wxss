/* pages/payment/payment.wxss */

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.info-row:last-child { border-bottom: none; }

.info-label {
  font-size: 28rpx;
  color: var(--label-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--label);
  font-weight: 500;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: var(--label-secondary);
}

.price-value {
  font-size: 28rpx;
  color: var(--label);
}

.price-row.discount .price-value { color: var(--green); }

.price-row.total .price-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--label);
}

/* 支付按钮 */
.pay-section {
  margin-top: 40rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.pay-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
}

.pay-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--label-tertiary);
  margin-top: 16rpx;
}

/* 状态区域 */
.status-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx 40rpx;
  margin-top: 20rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 122, 255, 0.06);
}

.status-icon.completed { background: rgba(52, 199, 89, 0.08); }
.status-icon.paid { background: rgba(0, 122, 255, 0.06); }

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--label);
  margin-bottom: 8rpx;
}

.status-hint {
  font-size: 26rpx;
  color: var(--label-secondary);
  margin-bottom: 48rpx;
}

.status-section button {
  width: 60%;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--label-secondary);
  font-size: 28rpx;
}
