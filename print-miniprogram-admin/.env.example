# ===== 服务配置 =====
PORT=3000
NODE_ENV=production
JWT_SECRET=your-random-secret-string-here

# ===== 微信小程序 =====
WX_APPID=your_appid
WX_APPSECRET=your_appsecret

# ===== MySQL 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
